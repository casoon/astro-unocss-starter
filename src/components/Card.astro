---
export interface Props {
	title: string;
	body: string;
	href: string;
}

const { href, title, body } = Astro.props;
---

<li class="link-card">
	<a href={href}>
		<h2>
			{title}
			<span aria-hidden="true" class="i-lucide-arrow-up-right"></span>
		</h2>
		<p>
			{body}
		</p>
	</a>
</li>
<style>
	.link-card {
		list-style: none;
	}

	.link-card > a {
		display: block;
		text-decoration: none;
		line-height: 1.4;
		padding: 1.25rem;
		border: 1px solid rgba(22, 32, 29, 0.1);
		border-radius: 1rem;
		color: #16201d;
		background-color: rgba(248, 245, 239, 0.78);
		box-shadow: 0 24px 70px rgba(22, 32, 29, 0.1);
		transition:
			border-color 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	h2 {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin: 0;
		font-size: 1.25rem;
	}

	p {
		margin-top: 0.5rem;
		margin-bottom: 0;
		color: rgba(22, 32, 29, 0.68);
	}

	.link-card > a:is(:hover, :focus-visible) {
		border-color: rgba(63, 127, 104, 0.4);
		color: #3f7f68;
		transform: translateY(-0.25rem);
	}
</style>
